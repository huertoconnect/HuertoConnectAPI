# ========================
# Huerto Connect Backend
# ========================

# --- General ---
API_PORT=8000
FRONTEND_URL=http://localhost:4200
FRONTEND_ORIGIN=http://localhost:4200

# --- MongoDB ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=huerto_connect
MONGO_USER=huerto_admin
MONGO_PASSWORD=huerto_secret_2026
MONGO_URI=mongodb://huerto_admin:huerto_secret_2026@mongodb:27017/huerto_connect?authSource=admin
# Alias compatible con auth_service standalone
MONGO_URL=mongodb://huerto_admin:huerto_secret_2026@localhost:27017/huerto_connect?authSource=admin
DB_NAME=huerto_connect

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=huerto_connect_ai
POSTGRES_USER=huerto_pg_admin
POSTGRES_PASSWORD=huerto_pg_secret_2026
POSTGRES_URI=postgresql://huerto_pg_admin:huerto_pg_secret_2026@postgres:5432/huerto_connect_ai

# --- JWT ---
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8
JWT_EXPIRE_HOURS=8

# --- OTP ---
OTP_HASH_SECRET=change-me-otp-secret
OTP_EXPIRATION_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=3
OTP_DELIVERY_MODE=smtp
OTP_EXPOSE_CODE_IN_RESPONSE=true

# --- SMTP (Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=huertoconnect@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
CONTACT_INBOX_EMAIL=huertoconnec@gmail.com
# Alias fastapi-mail
MAIL_USERNAME=huertoconnect@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=huertoconnect@gmail.com
MAIL_SERVER=smtp.gmail.com

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Cloudinary ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Password ---
AUTH_PASSWORD_PEPPER=change-me-pepper-secret

# --- Admin Seed ---
ADMIN_EMAIL=admin@huertoconnect.com
ADMIN_PASSWORD=Admin123!
ADMIN_NOMBRE=Administrador
ADMIN_APELLIDOS=Sistema
